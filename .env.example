# Server
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/secret_drop

# AES-256-GCM master key — MUST be exactly 64 hex characters (32 bytes)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=replace_with_64_char_hex_string

# Allowed origin for CORS (where your web/index.html is served from)
FRONTEND_ORIGIN=http://localhost:5500
